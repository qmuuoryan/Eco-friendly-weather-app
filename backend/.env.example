APP_NAME=WeatherAI Eco Agri Dashboard API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
WEATHER_AI_API_KEY=
WEATHER_AI_API_URL=https://api.weather-ai.co/v1/weather

# HTTP client settings
WEATHER_AI_TIMEOUT_SECONDS=10.0
WEATHER_AI_MAX_RETRIES=3

# Local fallback settings (leave API key empty to use fallback)
WEATHER_ENABLE_LOCAL_FALLBACK=true
WEATHER_FALLBACK_WIND_SPEED_KPH=10.0
WEATHER_FALLBACK_SOIL_MOISTURE_PERCENT=25.0
WEATHER_FALLBACK_RAINFALL_MM=0.0
WEATHER_FALLBACK_TEMPERATURE_OFFSET=0.0

# Copy this file to .env and edit secrets as needed. Do not commit .env.APP_NAME=WeatherAI Eco Agri Dashboard API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000
WEATHER_AI_API_KEY=
WEATHER_AI_API_URL=https://api.weatherai.com/v1/weather
